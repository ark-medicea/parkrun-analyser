{
  "name": "parkrun-analyser",
  "version": "2.0.0",
  "description": "ParkRun family dashboard — SQLite + sql.js architecture",
  "private": true,
  "scripts": {
    "scrape:discover": "node scraper/discover.js",
    "scrape:update": "node scraper/update.js",
    "scrape": "npm run scrape:discover && npm run scrape:update",
    "db:init": "node scraper/generate-sample-data.js",
    "db:export": "cp data/parkrun.db docs/data/parkrun.db"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "playwright": "^1.45.0"
  }
}
